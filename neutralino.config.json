{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.astradesk.app",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": { "enabled": true, "writeToLogFile": true },
  "nativeAllowList": [
    "app.*", "os.*", "filesystem.*", "storage.*",
    "computer.*", "debug.log", "window.*", "events.*"
  ],
  "modes": {
    "window": {
      "title": "AstraDesk",
      "width": 440,
      "height": 900,
      "minWidth": 340,
      "minHeight": 500,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/resources/icons/appIcon.png",
      "enableInspector": false,
      "borderless": true,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true,
      "transparent": false
    }
  },
  "cli": {
    "binaryName": "astradesk",
    "resourcesPath": "/resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "6.7.0",
    "clientVersion": "6.7.0"
  }
}